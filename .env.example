# -----------------------------------------------------------------------------
# Group booking tool — environment variables
# -----------------------------------------------------------------------------

# Path to the SQLite file. Relative paths are resolved against the working
# directory the server was started in. Back this file up — it contains every
# experiment, booking, and participant.
DATABASE_URL=local.db

# Public origin of this deployment, e.g. "https://booking.example.org".
# Used by better-auth for cookie scoping and to render absolute ICS feed URLs.
ORIGIN=""

# Better Auth
# For production use 32+ characters of high-entropy random.
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Clinic / lab timezone. All recurrence templates are expressed in wall-clock
# time in this zone, so set this to the researcher's local zone.
# Any IANA zone string is accepted, e.g. "America/New_York", "Asia/Tokyo".
CLINIC_TZ=Europe/Copenhagen

# Initial admin — used only by `pnpm seed:admin` on first setup. Signup is
# locked once any user row exists, so these values only take effect once.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# Port the Node server listens on. Also controls the host-side port binding in
# docker-compose.yml. Change this if 3000 conflicts with another service.
APP_PORT=3000

# Optional: append structured JSON log lines to this file. Leave empty to log
# only to stdout/stderr (which is the usual setup behind a process manager).
LOG_FILE=""

# GDPR: global default number of days to retain participant data after an
# experiment's end date.  Per-experiment overrides are configurable in the
# admin panel.  Must be a positive integer.
DATA_RETENTION_DAYS=90

# Data controller contact information shown on the /privacy page.
# DATA_CONTROLLER_EMAIL falls back to ADMIN_EMAIL when left blank.
DATA_CONTROLLER_NAME=""
DATA_CONTROLLER_EMAIL=""

# Base path when the app is served from a subdirectory behind a reverse proxy
# (e.g. BASE_PATH=/booking to serve at https://example.org/booking).
# Must start with "/" and must NOT end with "/". Leave empty for root ("/").
# IMPORTANT: this is a BUILD-TIME setting — changing it requires rebuilding the
# image (`docker compose build`).  It is NOT read at server start-up.
BASE_PATH=

# Set to "cloudflare" if this deployment is proxied through Cloudflare.
# Without this, the rate limiter keys on X-Forwarded-For, which a client can
# spoof when Cloudflare is in the path. Setting this makes it use
# CF-Connecting-IP instead, which Cloudflare controls and clients cannot forge.
TRUSTED_PROXY=""
